---
import { ArrowRight, BookOpen, CalendarDays, MapPin, Sigma, Trophy } from "@lucide/astro";
import SiteLayout from "../layouts/SiteLayout.astro";
---

<SiteLayout title="Home" description="Competition, community, and mathematical exploration at Bergen County Academies.">
  <main id="main-content" class="home-page">
    <section class="home-hero">
      <img
        src="/images/math_team_lecture_reduced.jpg"
        alt="BCA Math Team students working together during a lecture"
        width="2200"
        height="1650"
      />
      <div class="home-hero__shade"></div>
      <div class="home-hero__content">
        <p class="eyebrow">Bergen County Academies</p>
        <h1>Think deeply.<br />Solve together.</h1>
        <p class="home-hero__intro">
          A community for students who enjoy hard problems, elegant ideas, and learning mathematics with others.
        </p>
        <div class="home-hero__actions">
          <a class="button button--primary" href="#join">Join the team <ArrowRight size={18} /></a>
          <a class="button button--glass" href="/archive.html">Explore the archive</a>
        </div>
      </div>
      <div class="home-hero__meta" aria-label="Meeting information">
        <span><CalendarDays size={18} /> Most Saturdays</span>
        <span><MapPin size={18} /> Bergen County Academies</span>
        <span>Open to high school students</span>
      </div>
    </section>

    <section class="home-intro page-band">
      <div class="home-intro__heading">
        <p class="eyebrow eyebrow--red">About the team</p>
        <h2>One of the Academies’ oldest and largest student communities.</h2>
      </div>
      <div class="home-intro__copy">
        <p>
          We compete nationally, host weekly lectures and practices, and travel to tournaments at schools including
          Princeton, Harvard, MIT, Penn State, Carnegie Mellon, Seton Hall, and Stanford.
        </p>
        <a class="text-link" href="/about.html">How the team works <ArrowRight size={17} /></a>
      </div>
    </section>

    <section class="home-paths page-band page-band--tint" aria-labelledby="explore-heading">
      <div class="section-heading">
        <p class="eyebrow eyebrow--red">Start here</p>
        <h2 id="explore-heading">Find your next problem.</h2>
      </div>
      <div class="feature-grid">
        <a class="feature-card" href="/archive.html">
          <span class="feature-card__icon"><BookOpen size={25} /></span>
          <span class="feature-card__number">01</span>
          <h3>Lecture archive</h3>
          <p>Past notes, problem sets, contests, and solutions organized by season.</p>
          <span class="text-link">Browse materials <ArrowRight size={17} /></span>
        </a>
        <a class="feature-card" href="/info.html">
          <span class="feature-card__icon"><Sigma size={25} /></span>
          <span class="feature-card__number">02</span>
          <h3>Contest preparation</h3>
          <p>Guides and resources for AMC, AIME, olympiad, and independent practice.</p>
          <span class="text-link">Prepare to compete <ArrowRight size={17} /></span>
        </a>
        <a class="feature-card" href="/news.html">
          <span class="feature-card__icon"><Trophy size={25} /></span>
          <span class="feature-card__number">03</span>
          <h3>Results and awards</h3>
          <p>Highlights from the team’s long history of regional, national, and international competition.</p>
          <span class="text-link">See our results <ArrowRight size={17} /></span>
        </a>
      </div>
    </section>

    <section id="join" class="home-join page-band">
      <div class="home-join__visual">
        <img
          src="/images/jhmmc_volunteers_reduced.jpeg"
          alt="BCA Math Team students volunteering together"
          width="2200"
          height="1468"
          loading="lazy"
        />
      </div>
      <div class="home-join__content">
        <p class="eyebrow eyebrow--red">Registration</p>
        <h2>There is a place here for every serious learner.</h2>
        <p>
          The high school program welcomes students at every level of competition experience. Students in grade 8 and
          below should use the separate registration form and review the current team policies before registering.
        </p>
        <div class="home-join__links">
          <a class="button button--dark" href="https://forms.gle/115r5tdH7xRwuvW96">Register for grades 9–12 <ArrowRight size={18} /></a>
          <a class="button button--outline" href="https://forms.gle/gY9snTBKPJrLrrzb6">Register for grade 8 and below</a>
        </div>
        <a class="text-link text-link--muted" href="/files25-26/Math Team Policies 2025-26.pdf">Read the 2025–26 policies</a>
      </div>
    </section>

    <section class="home-submit page-band page-band--dark">
      <div>
        <p class="eyebrow">For current members</p>
        <h2>Finished this week’s problem set?</h2>
      </div>
      <div>
        <p>Intermediate room work is typically due before the following Math Team meeting.</p>
        <a class="button button--light" href="https://forms.gle/oXeJHpMQBCCW1ZiH9">Submit your work <ArrowRight size={18} /></a>
      </div>
    </section>
  </main>
</SiteLayout>
